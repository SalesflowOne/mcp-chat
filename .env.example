# =============================================================================
# AgentOps / mcp-chat — environment variables
# Copy to .env for local development: cp .env.example .env
# For Vercel: Project Settings → Environment Variables (Production)
# =============================================================================

# --- AI providers (at least one required for chat) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
EXA_API_KEY=

# --- Pipedream MCP (required for tool integrations) ---
# https://pipedream.com/docs/connect/mcp/developers/#prerequisites
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_ENVIRONMENT=production
# Optional override for MCP server URL (default: https://remote.mcp.pipedream.net)
# MCP_SERVER=

# --- Auth (NextAuth v5) ---
# Generate: openssl rand -base64 32  OR  https://generate-secret.vercel.app/32
AUTH_SECRET=

# Google OAuth (required when DISABLE_AUTH is not true)
# Add redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (required when DISABLE_PERSISTENCE is not true) ---
# Vercel: add Neon Postgres from Marketplace — POSTGRES_URL is auto-injected
POSTGRES_URL=

# --- Feature flags ---
# Local dev defaults (see README). For production AgentOps, set both to false.
DISABLE_AUTH=true
DISABLE_PERSISTENCE=true

# External user id for Pipedream Connect when auth is disabled (dev only)
EXTERNAL_USER_ID=

# --- Vercel Blob (file uploads in chat; auto-set when Blob store is linked) ---
# BLOB_READ_WRITE_TOKEN=

# --- Optional ---
# ENV_FILE_PATH=
# NEXT_PUBLIC_COOKIEBOT_ID=
# NEXT_PUBLIC_DATADOG_APPLICATION_ID=
# NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=
