# =============================================================================
# AgentOps / One OS (mcp-chat) — environment variables
# Copy: cp .env.example .env.local
# =============================================================================

# --- AI providers (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
EXA_API_KEY=

# --- Pipedream MCP ---
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_ENVIRONMENT=production

# --- Clerk (identity + organizations) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# agentops.one is a Clerk satellite — sign-in on Account Portal (not embedded on agentops.one)
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=agentops.one
# Account Portal on agentops (CNAME accounts.agentops.one → accounts.clerk.services)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://accounts.agentops.one/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://accounts.agentops.one/sign-up
NEXT_PUBLIC_CLERK_PROXY_URL=https://agentops.one/__clerk
NEXT_PUBLIC_APP_URL=https://agentops.one
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=https://agentops.one/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=https://agentops.one/
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=https://agentops.one/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=https://agentops.one/

# --- Supabase (application data — multi-tenant) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags ---
# Production: DISABLE_AUTH=false, DISABLE_PERSISTENCE=false (when Supabase is configured)
DISABLE_AUTH=true
DISABLE_PERSISTENCE=true

# Dev-only guest user for Pipedream when auth is disabled
EXTERNAL_USER_ID=

# Legacy Drizzle/Neon (optional fallback for artifacts/documents)
# POSTGRES_URL=

# Optional
# BLOB_READ_WRITE_TOKEN=
# MCP_SERVER=
