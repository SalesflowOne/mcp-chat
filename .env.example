# =============================================================================
# AgentOps / One OS (mcp-chat) — environment variables
# Copy: cp .env.example .env.local
# =============================================================================

# --- AI providers (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
EXA_API_KEY=

# --- Pipedream MCP ---
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_ENVIRONMENT=production

# --- Supabase (auth + application data) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AGENTOPS_PERSIST_SECRET=

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://agentops.one

# --- Vercel (Space deploy to production) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=team_Na274IDFwAHRPi5JdFrzvRUk

# --- Feature flags (production: both false) ---
DISABLE_AUTH=false
DISABLE_PERSISTENCE=false

EXTERNAL_USER_ID=
